@model Schulbibliothek.Viewmodels.TransaktionenViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Status</th>
                <th>BuchTitel</th>
                <th>Datum</th>
                <th>Name</th>
                <th>Bild</th>
                <th>Beschreibung</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var transaktion in Model.Transaktionen)
            {
                <tr>
                    <td>@transaktion.IstAusgeliehen</td>
                    <td>@transaktion.Buchtitel</td>
                    <td>@transaktion.Datum</td>
                    <td>@transaktion.PersonName</td>
                    <td>@transaktion.BildLink<td>
                    <td>@transaktion.Beschreibung</td>
                </tr>
            }
        </tbody>
    </table>
</div>
